pipeline {
    agent { label 'windows-agent-1' }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Select Terraform Action'
        )
    }

    environment {
        TF_DIR = "repo/terraform"
        ACR_NAME = "jdacr12345"
        IMAGE_NAME = "jdapp"
        RG = "jd-aks-rg"
        AKS = "jd-aks-cluster"
        PATH = "C:\\Program Files (x86)\\Microsoft SDKs\\Azure\\CLI2\\wbin;${env.PATH}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/jerolddraj-oss/AKS.git'
            }
        }

        stage('Debug Files') {
            steps {
                bat 'echo ===== TF FILES ====='
                bat 'dir /s *.tf'
            }
        }

        // 🔐 Azure Login
        stage('Azure Login') {
            steps {
                withCredentials([
                    string(credentialsId: 'AZURE_CLIENT_ID', variable: 'AZ_CLIENT_ID'),
                    string(credentialsId: 'AZURE_CLIENT_SECRET', variable: 'AZ_CLIENT_SECRET'),
                    string(credentialsId: 'AZURE_TENANT_ID', variable: 'AZ_TENANT_ID'),
                    string(credentialsId: 'AZURE_SUBSCRIPTION_ID', variable: 'AZ_SUB_ID')
                ]) {

                    bat """
                    az login --service-principal ^
                      --username %AZ_CLIENT_ID% ^
                      --password %AZ_CLIENT_SECRET% ^
                      --tenant %AZ_TENANT_ID%
                    """

                    bat "az account set --subscription %AZ_SUB_ID%"
                }
            }
        }

        stage('Verify Azure Login') {
            steps {
                bat 'az account show'
            }
        }

        // 🔧 Terraform Init
        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    bat 'terraform init'
                }
            }
        }

        // 📊 Terraform Plan
        stage('Terraform Plan') {
            when {
                expression { params.ACTION == 'plan' || params.ACTION == 'apply' }
            }
            steps {
                dir("${TF_DIR}") {
                    bat 'terraform plan -out=tfplan'
                }
            }
        }

        // 🚀 Terraform Apply
        stage('Terraform Apply') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                input message: 'Approve APPLY?', ok: 'Yes'
                dir("${TF_DIR}") {
                    bat 'terraform apply -auto-approve tfplan'
                }
            }
        }

        // 💣 Terraform Destroy
        stage('Terraform Destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                input message: '⚠️ Confirm DESTROY?', ok: 'Destroy'
                dir("${TF_DIR}") {
                    bat 'terraform destroy -auto-approve'
                }
            }
        }

        // 🐳 Build (only if APPLY)
        stage('Build Image') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                dir('repo/app') {
                    bat "docker build -t %ACR_NAME%.azurecr.io/%IMAGE_NAME%:latest ."
                }
            }
        }

        // 📦 Push (only if APPLY)
        stage('Push Image') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                bat "az acr login --name %ACR_NAME%"
                bat "docker push %ACR_NAME%.azurecr.io/%IMAGE_NAME%:latest"
            }
        }

        // 🚀 Deploy (only if APPLY)
        stage('Deploy to AKS') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                bat "az aks get-credentials --resource-group %RG% --name %AKS% --overwrite-existing"
                bat "kubectl apply -f repo/k8s/deployment.yaml"
                bat "kubectl apply -f repo/k8s/service.yaml"
            }
        }
    }

    post {
        success {
            echo "✅ Action ${params.ACTION} completed successfully"
        }
        failure {
            echo "❌ Action ${params.ACTION} failed"
        }
    }
}
